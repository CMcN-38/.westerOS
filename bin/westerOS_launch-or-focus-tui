#!/usr/bin/env bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like westerOS-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.westerOS.$(basename "$1")"
LAUNCH_COMMAND="westerOS_launch-tui $@"

exec westerOS_launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
